# Environment Variables for Social Publishing Backend
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file to version control.

# Port the server listens on
PORT=3000

# Secret key used to sign JWT tokens.
# Change this to a long, random string in production!
JWT_SECRET=ShibamVibeCastSecret2024SecureKey!@#

# ── Frontend URL (used in invite & password reset emails) ─────
FRONTEND_URL=http://localhost:5173

# ── Email / SMTP Configuration ────────────────────────────────
# To send real emails, use Gmail SMTP with an App Password.
# Generate App Password at: https://myaccount.google.com/apppasswords
# Leave EMAIL_HOST blank to use console-only dev fallback (no real email sent).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=Shibam.seal4@gmail.com
# TODO: Replace with your Gmail App Password (16-char code, no spaces)
EMAIL_PASS=your_gmail_app_password_here
